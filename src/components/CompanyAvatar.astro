---
// Deterministic monogram avatar — adds shape/recognizability without stock logos.
// Mono-brand: dark tile, faint orange-tinted ring, cream initials.
interface Props { name: string; size?: number; }
const { name, size = 44 } = Astro.props;

function initials(n: string): string {
  const words = n.replace(/[^\p{L}\p{N} ]/gu, ' ').split(/\s+/).filter(Boolean);
  if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
  return n.replace(/[^\p{L}\p{N}]/gu, '').slice(0, 2).toUpperCase();
}
const text = initials(name);
const fs = text.length > 1 ? size * 0.4 : size * 0.5;
---
<span class="ava" style={`--s:${size}px`} aria-hidden="true">
  <span class="ava__t" style={`font-size:${fs}px`}>{text}</span>
</span>
<style>
  .ava {
    flex: none; display: inline-grid; place-items: center;
    width: var(--s); height: var(--s); border-radius: 12px;
    background: radial-gradient(120% 120% at 30% 20%, rgba(255,61,0,.16), transparent 60%), var(--card-2);
    border: 1px solid var(--accent-line);
    box-shadow: inset 0 1px 0 rgba(255,216,199,.06);
  }
  .ava__t { font-weight: 800; letter-spacing: -0.03em; color: var(--cream); line-height: 1; }
</style>

---
import TelegramIcon from './icons/TelegramIcon.astro';
import { tg } from '../lib/site';
import data from '../data/cases.json';
interface Props { heading?: string; alt?: boolean; }
const { heading = 'Кейсы и отзывы', alt = false } = Astro.props;
const cases = data.cases as Array<{ img: string; tag: string; quote: string; detail: string }>;
const facts = data.facts as Array<{ num: string; label: string }>;
---
<section class={`section cases ${alt ? 'section--alt' : ''}`}>
  <div class="container">
    <div class="accent-bar"></div>
    <h2>{heading}</h2>
    <p class="lead">Реальные отзывы подписчиков после собеседований — со скриншотами, без прикрас. Личные данные скрыты.</p>

    <ul class="cfacts">
      {facts.map((f) => <li><b>{f.num}</b><span>{f.label}</span></li>)}
    </ul>

    <div class="cgrid">
      {cases.map((c) => (
        <figure class="ccard">
          <span class="ccard__tag">{c.tag}</span>
          <button type="button" class="ccard__imgwrap" data-lightbox-img={c.img} data-lightbox-group="cases" data-lightbox-cap={c.quote} aria-label="Открыть отзыв крупнее"><img src={c.img} alt={`Отзыв JavaJub: ${c.quote}`} loading="lazy" /><span class="ccard__zoom" aria-hidden="true">⤢</span></button>
          <figcaption>
            <p class="ccard__q">«{c.quote}»</p>
            <p class="ccard__d muted">{c.detail}</p>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="crow">
      <a class="btn btn--tg" href={tg('cases')} target="_blank" rel="noreferrer"><TelegramIcon /> Все отзывы в канале</a>
      <a class="btn btn--ghost" href="https://habr.com/ru/articles/1043906/" target="_blank" rel="noreferrer">Разбор 247 собесов на Habr →</a>
    </div>
  </div>
</section>
<style>
  .cfacts { list-style: none; margin: 1.2rem 0 0; padding: 1rem 0 0; border-top: 1px solid var(--border);
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .cfacts li { display: flex; flex-direction: column; gap: .15rem; }
  .cfacts b { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; letter-spacing: -.03em; color: var(--accent-light); white-space: nowrap; }
  .cfacts span { font-size: .85rem; color: var(--text-soft); }

  .cgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; margin-top: 1.8rem; }
  .ccard { position: relative; margin: 0; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
    overflow: hidden; display: flex; flex-direction: column; transition: transform .14s ease, border-color .14s ease, box-shadow .14s ease; }
  .ccard:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 16px 34px rgba(0,0,0,.32); }
  .ccard__tag { position: absolute; top: .8rem; left: .8rem; z-index: 1; font-family: var(--font-mono); font-size: .68rem;
    font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--contrast); background: var(--accent); border-radius: 999px; padding: .22rem .6rem; }
  .ccard__imgwrap { position: relative; display: block; width: 100%; padding: 0; border: 0; border-bottom: 1px solid var(--border);
    background: #0e1116; aspect-ratio: 16 / 11; overflow: hidden; cursor: zoom-in; }
  .ccard__imgwrap img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  .ccard__zoom { position: absolute; top: .6rem; right: .6rem; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center;
    background: rgba(9,8,7,.6); color: #fff; font-size: .95rem; opacity: 0; transition: opacity .14s ease; }
  .ccard__imgwrap:hover .ccard__zoom, .ccard__imgwrap:focus-visible .ccard__zoom { opacity: 1; }
  .ccard figcaption { padding: .9rem 1.1rem 1.1rem; }
  .ccard__q { margin: 0 0 .35rem; font-weight: 700; color: var(--cream); line-height: 1.35; }
  .ccard__d { margin: 0; font-size: .88rem; }
  .crow { display: flex; gap: .6rem; flex-wrap: wrap; margin-top: 1.6rem; }
  @media (max-width: 820px) { .cgrid { grid-template-columns: 1fr; } .cfacts { grid-template-columns: 1fr 1fr; } }
</style>

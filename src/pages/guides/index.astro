---
import Base from '../../layouts/Base.astro';
import TelegramIcon from '../../components/icons/TelegramIcon.astro';
import ProGuides from '../../components/ProGuides.astro';
import { tg } from '../../lib/site';
import { guides, guidesStats } from '../../lib/guides';
import { stats, ru, qWord } from '../../lib/companies';

const title = 'Гайды по собеседованиям Java — реальные вопросы по компаниям | JavaJub';
const description = `Бесплатные гайды по собеседованиям Java: Сбер, Альфа-Банк, VK, Яндекс, Т1, Лига и другие. ${guidesStats.totalQuestions}+ реальных вопросов с ответами по грейдам — скачивай PDF и готовься прицельно.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Гайды по собеседованиям Java',
  itemListElement: guides.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `Собеседование Java в ${g.company} — ${g.grade}`,
    url: `https://www.javajub.com${g.pdf}`,
  })),
};
---
<Base title={title} description={description} jsonLd={jsonLd}>
  <section class="section">
    <div class="container">
      <nav class="crumbs mono"><a href="/">главная</a> <span>/</span> <b>гайды</b></nav>
      <div class="accent-bar"></div>
      <h1>Гайды по <span class="hl">собеседованиям Java</span></h1>
      <p class="lead">Реальные вопросы, задачи и кейсы с собесов в конкретных компаниях — собрано по грейдам.
        Первые разделы — прямо здесь. <b>Полный гайд</b> (все вопросы с ответами, задачи и чек-лист «за 2 часа») — бесплатно в Telegram-канале.</p>

      <ul class="gstats">
        <li><b>{guidesStats.count}</b> бесплатных гайдов</li>
        <li><b>{ru(guidesStats.totalQuestions)}+</b> вопросов с ответами</li>
        <li><b>{ru(stats.companies)}</b> компаний в базе</li>
      </ul>

      <div class="ggrid">
        {guides.map((g) => (
          <article class="gcard">
            <div class="gcard__cover" role="button" tabindex="0" aria-label={`Посмотреть обложку: ${g.company}`}
                 data-lightbox-img={g.cover} data-lightbox-cap={`Гайд: собеседование Java в ${g.company} · ${g.grade}`}>
              <span class={`gcard__kind ${g.kind === 'review' ? 'is-review' : ''}`}>{g.kind === 'review' ? 'разбор' : 'гайд'} · превью</span>
              <img src={g.cover} alt={`Гайд JavaJub: собеседование Java в ${g.company}, ${g.grade}`} loading="lazy" width="320" height="453" />
              <span class="gcard__zoom" aria-hidden="true">⤢</span>
            </div>
            <div class="gcard__body">
              <h2 class="gcard__title">{g.company}</h2>
              <div class="gcard__meta">
                <span class="pill pill--accent">{g.grade}</span>
                {g.questionCount && <span class="mono faint">{g.questionCount} {qWord(g.questionCount)}</span>}
              </div>
              <p class="gcard__sum">{g.summary}</p>
              <div class="gcard__stack">
                {g.stack.slice(0, 6).map((s) => <span class="tag">{s}</span>)}
              </div>
              <div class="gcard__btns">
                <a class="btn btn--tg" href={tg(`guide_${g.slug}`)} target="_blank" rel="noreferrer"><TelegramIcon /> Полный гайд в канале</a>
                <a class="btn btn--ghost" href={g.pdf} target="_blank" rel="noreferrer"
                   data-lightbox-pdf={g.pdf} data-lightbox-cap={`Превью гайда: собеседование Java в ${g.company} · ${g.grade}`}>Превью (10 стр.)</a>
                {g.companySlug && <a class="btn btn--ghost" href={`/companies/${g.companySlug}/`}>Вопросы компании</a>}
              </div>
              <span class="gcard__note mono faint">первые разделы бесплатно · полностью — в @java_jub</span>
            </div>
          </article>
        ))}
      </div>

      <div class="card gmore">
        <div>
          <div class="accent-bar"></div>
          <h2 style="margin:0 0 .4rem">Это бесплатные гайды. А есть ещё платные</h2>
          <p class="muted" style="margin:0">Ещё 20+ разборов — Сбер Senior, Т-Банк, ВТБ, Ozon, Альфа и другие — в Pro. Ниже можно заглянуть в их содержание, или заказать разбор под свою компанию ({ru(stats.companies)} в базе).</p>
        </div>
        <div class="gmore__btns">
          <a class="btn btn--ghost" href="/order/">Заказать гайд</a>
          <a class="btn btn--tg" href={tg('guides')} target="_blank" rel="noreferrer"><TelegramIcon /> В Telegram</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Paid guides: cover + содержание only (no questions, no PDFs) -->
  <ProGuides alt heading="Платные гайды — загляни в содержание" intro="Гайды Pro по компаниям, которых нет в бесплатных. Показываем только титульный лист и содержание — сами вопросы и ответы открываются по подписке." />
</Base>
<style>
  .crumbs { color: var(--text-faint); font-size: .82rem; margin-bottom: 1rem; }
  .crumbs a:hover { color: var(--accent-light); } .crumbs span { opacity: .5; } .crumbs b { color: var(--text-soft); }

  .gstats { list-style: none; display: flex; flex-wrap: wrap; gap: .6rem 1.6rem; margin: 1.4rem 0 0; padding: 1rem 0 0; border-top: 1px solid var(--border); }
  .gstats li { color: var(--text-soft); font-size: .95rem; }
  .gstats b { color: var(--cream); font-weight: 800; font-size: 1.15rem; letter-spacing: -.02em; margin-right: .25rem; }

  .ggrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 21rem), 1fr)); gap: 1.2rem; margin-top: 2rem; }
  .gcard { display: flex; flex-direction: column; background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden; transition: transform .14s ease, border-color .14s ease, box-shadow .14s ease; }
  .gcard:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 18px 38px rgba(0,0,0,.4); }
  .gcard__cover { position: relative; display: grid; place-items: center; padding: 1.3rem 1.3rem 0; cursor: zoom-in;
    background: radial-gradient(120% 80% at 50% 0, var(--accent-soft), transparent 70%), var(--card-2); }
  .gcard__cover:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }
  .gcard__zoom { position: absolute; top: .7rem; right: .7rem; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center;
    background: rgba(9,8,7,.62); color: #fff; font-size: .95rem; opacity: 0; transition: opacity .14s ease; pointer-events: none; }
  .gcard__cover:hover .gcard__zoom, .gcard__cover:focus-visible .gcard__zoom { opacity: 1; }
  .gcard__cover img { width: 64%; max-width: 190px; height: auto; border-radius: 6px;
    box-shadow: 0 14px 30px rgba(0,0,0,.45); border: 1px solid rgba(0,0,0,.1); }
  .gcard__kind { position: absolute; top: .8rem; left: .8rem; z-index: 1; font-family: var(--font-mono);
    font-size: .66rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
    color: var(--accent-light); background: var(--bg); border: 1px solid var(--border-strong); border-radius: var(--radius-pill); padding: .2rem .55rem; }
  .gcard__kind.is-review { color: var(--cream); }
  .gcard__body { display: flex; flex-direction: column; gap: .55rem; padding: 1.1rem 1.2rem 1.25rem; flex: 1; }
  .gcard__title { margin: 0; font-size: 1.25rem; }
  .gcard__meta { display: flex; align-items: center; gap: .7rem; flex-wrap: wrap; }
  .gcard__sum { color: var(--text-soft); font-size: .92rem; margin: 0; line-height: 1.5; }
  .gcard__stack { display: flex; flex-wrap: wrap; gap: .3rem; margin-top: .1rem; }
  .gcard__btns { display: flex; gap: .5rem; flex-wrap: wrap; margin-top: auto; padding-top: .6rem; }
  .gcard__btns .btn { padding: .6rem .9rem; font-size: .9rem; }
  .gcard__note { display: block; margin-top: .5rem; font-size: .72rem; letter-spacing: .01em; }

  .gmore { display: flex; align-items: center; justify-content: space-between; gap: 1.4rem; flex-wrap: wrap;
    margin-top: 2rem; background: linear-gradient(120deg, var(--card), var(--card-2)); border-color: var(--border-strong); }
  .gmore__btns { display: flex; gap: .6rem; flex-wrap: wrap; }
</style>

# JavaJub web — public build-time vars (baked into the static site).
# Base URL of the javajub-api backend. Leave EMPTY to use same-origin "/api"
# (recommended: a reverse proxy like Caddy serves the site and proxies /api/*).
# Set to the API origin (e.g. https://api.javajub.com) for split hosting.
PUBLIC_API_BASE=

# Privacy-friendly, COOKIELESS analytics (variant B). Leave EMPTY = no analytics,
# no cookies, no third-party requests, no personal data (default = compliant).
# To enable: stand up a self-hosted cookieless analytics (recommended: Umami,
# ideally on a server in RF) and set both vars to its script URL + site id.
#   PUBLIC_ANALYTICS_SRC=https://analytics.yourdomain.ru/script.js
#   PUBLIC_ANALYTICS_ID=<website-id-uuid>
# The tag is injected with data-do-not-track="true" (no cookies, IP not stored).
PUBLIC_ANALYTICS_SRC=
PUBLIC_ANALYTICS_ID=

# Optional overrides for the data pipeline (defaults point at the local base):
# JAVAJUB_COMPANIES_DIR=/path/to/your/companies
# JAVAJUB_VACANCIES_DB=/path/to/vacancies.db
